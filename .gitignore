node_modules
dist
dist-ssr
# Ignore every local/dev env file (.env, .env.local, .env.development, …) so an
# opt-in like VITE_MOCK_AUTH can never be committed; .env.example stays tracked.
.env
.env.*
!.env.example
*.log
npm-debug.log*
.DS_Store
.vercel
.vscode/*
!.vscode/extensions.json
.gstack/

.vercel

# transient DB connection string for one-off migrations (never commit)
.db-conn
# Supabase personal access token for CLI / function deploys (never commit)
.supabase-token
# Supabase CLI scratch dir (regenerated; never commit)
supabase/.temp/
