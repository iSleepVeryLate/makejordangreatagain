# Copy this file to .env.local and fill in your Supabase project values.
# Find these in your Supabase dashboard: Project Settings -> API.

VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# Web Push (the "your turn" / challenge alerts). PUBLIC half of a VAPID key pair.
# Generate a pair with:  npx web-push generate-vapid-keys
# Put the PUBLIC key here; the PRIVATE key goes in the send-push Edge Function's
# secrets (see supabase/migrations/0012_web_push.sql for the full setup).
# Push only activates in production builds; leave blank to disable it.
VITE_VAPID_PUBLIC_KEY=

# DEV-ONLY mock auth. Set to 1 to bypass Discord login locally and boot straight
# into a fake signed-in user — useful for UI work / headless QA. Hard-gated to
# the dev server (`vite serve`) via a build-time constant, so it can NEVER take
# effect in a production build (`vite build`), even if this var is set. It
# unlocks routing/UI + anon-readable data only; real gameplay still needs a
# Discord login. Read from process env and any .env file — never commit it.
# Leave unset/0 for normal Discord auth.
# VITE_MOCK_AUTH=1
